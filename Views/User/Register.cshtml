@model ModelRegister
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "User Register";
    Layout = "_Layout";
}

<form class="form-control" asp-action="Register" asp-controller="User" method="post">
    <label asp-for="Username">Username</label>
    <input class="form-control" asp-for="Username" type="text" placeholder="username" />
    <label asp-for="Email">E-mail</label>
    <input class="form-control" asp-for="Email" type="email" placeholder="email" />
    <label asp-for="Password">Password</label>
    <input class="form-control" asp-for="Password" type="password" placeholder="password" />
    <button class="btn btn-success" type="submit">Register</button>
</form>