@model Product
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Product Details";
    Layout = "_Layout";
}

<div class="container mt-4">

    <div class="mb-3">
        <a class="btn btn-success" href="@Url.Action("Create", "Product")">Create</a>
        <a class="btn btn-info" href="@Url.Action("Read", "Category")">Category List</a>
        <a class="btn btn-secondary" href="@Url.Action("Index", "Product")">Back to List</a>
    </div>

    <div class="card shadow">
        <div class="card-header">
            <h2>Product Details</h2>
        </div>

        <div class="card-body">

            <table class="table table-bordered table-striped">
                <tbody>
                    <tr>
                        <th width="200">Id</th>
                        <td>@Model.Id</td>
                    </tr>

                    <tr>
                        <th>Name</th>
                        <td>@Model.Name</td>
                    </tr>

                    <tr>
                        <th>Description</th>
                        <td>@Model.Description</td>
                    </tr>

                    <tr>
                        <th>Price</th>
                        <td>@Model.Price.ToString("C")</td>
                    </tr>

                    <tr>
                        <th>Category Id</th>
                        <td>@Model.CategotyId</td>
                    </tr>

                    <tr>
                        <th>Quantity</th>
                        <td>@Model.Quantity</td>
                    </tr>

                    @if (Model.Category != null)
                    {
                        <tr>
                            <th>Category</th>
                            <td>@Model.Category.Name</td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>