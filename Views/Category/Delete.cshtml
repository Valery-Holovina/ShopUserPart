@model int
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Category Create";
    Layout = "_Layout";
}

<a class="btn btn-info" href="@Url.Action("Read", "Category")">Category List</a>

<form class="form-control" asp-action="DeletePost" asp-controller="Category" method="post">
    <input type="hidden" name="id" value="@Model" />
    <p>Are you sure you want to delete this category?</p>
    <button class="btn btn-danger" type="submit">Delete</button>
    <a class="btn btn-secondary" asp-action="Read" asp-controller="Category">Cancel</a>
</form>